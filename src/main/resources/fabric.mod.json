{
	"schemaVersion": 1,
	"id": "brapi",
	"version": "${version}",
	"name": "Brapi",
	"description": "A Fast UI rendering for Fabric mods. Rounded rectangles, gradients, textures and SDF text.",
	"authors": [
		"BSprout"
	],
	"contact": {
		"homepage": "https://modrinth.com/mod/brapi",
		"sources": "https://github.com/ifirsttealover/brapi"
	},
	"license": "CC0-1.0",
	"icon": "assets/brapi/icon.png",
	"environment": "*",
	"entrypoints": {
		"client": [
			"dev.bsprout.brapi.client.Brapi"
		]
	},
	"mixins": [
		{
			"config": "brapi.client.mixins.json",
			"environment": "client"
		}
	],
	"depends": {
		"fabricloader": ">=0.19.2",
		"minecraft": "~1.21.1",
		"java": ">=21",
		"fabric-api": "*"
